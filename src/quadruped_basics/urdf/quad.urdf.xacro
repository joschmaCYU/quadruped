<robot name="robot">
  <link name="base_footprint"></link>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.243 0.196 0.1" /> </geometry>
      <material name="base_link-material">
        <color rgba="0.054480276435339814 0.15292615198613213 0.407240211891531 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.243 0.196 0.1" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="0.16666666666666666" ixy="0" ixz="0" iyy="0.16666666666666666" iyz="0" izz="0.16666666666666666" />
    </inertial>
  </link>

  <joint name="base_link_to_cube5" type="revolute">
    <parent link="base_link" />
    <child link="cube5" />
    <origin xyz="0.069 0.098 -0.11469792884829269" rpy="-3.141592653589793 0 -3.141592653589793" />
    <axis xyz="0 0 1"/>
    <limit effort="1000.0"  velocity="0.5"/>
  </joint>
  <link name="cube5">
