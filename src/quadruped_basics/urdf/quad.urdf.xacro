  <joint name="belly_lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="belly_lidar_link"/>
    <origin xyz="0 0 -0.07" rpy="3.14159 0 0"/> 
  </joint>

  <link name="belly_lidar_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.04"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <gazebo reference="belly_lidar_link">
    <sensor name="belly_lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize> 
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.45</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <topic>scan</topic>
      <gz_frame_id>belly_lidar_link</gz_frame_id>
    </sensor>
  </gazebo>
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    

    <joint name="base_link_to_cube5">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="cube5_to_cube9">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>

    <joint name="base_link_to_cube6">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="cube6_to_cube10">
